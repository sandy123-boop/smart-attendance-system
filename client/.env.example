# ─── Production (Vercel) ───────────────────────────────────────────────────────
# Full URL to your Render backend, including /api path — used by axios
VITE_API_URL=https://your-app.onrender.com/api

# Full URL to your Render backend root — used by socket.io-client
VITE_SERVER_URL=https://your-app.onrender.com

# ─── Local dev ────────────────────────────────────────────────────────────────
# Leave these unset locally; the Vite dev proxy will handle /api and /socket.io
